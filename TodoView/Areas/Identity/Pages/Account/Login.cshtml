@page
@model LoginModel

@{
    ViewData["Title"] = "Log in";
    ViewData["HideNavbar"] = true;
}

<div class="container auth-shell">
    <div class="row justify-content-center w-100">
        <div class="col-12 col-md-6 col-lg-5">
            <div class="auth-card">
                <div class="auth-card-header text-center">
                    <h2 class="fw-bold mb-2">Welcome Back</h2>
                    <p class="mb-0">Sign in to continue managing tasks and users from the same calm workspace.</p>
                </div>
                <div class="auth-card-body">
                    <div class="text-center mb-4">
                        <span class="eyebrow">Account Access</span>
                    </div>

                    <form id="account" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small" role="alert"></div>

                        <div class="form-floating mb-3">
                            <input asp-for="Input.Email" class="form-control" autocomplete="username" placeholder="name@example.com" />
                            <label asp-for="Input.Email">Email Address</label>
                            <span asp-validation-for="Input.Email" class="text-danger small"></span>
                        </div>

                        <div class="form-floating mb-2">
                            <input asp-for="Input.Password" class="form-control" autocomplete="current-password" placeholder="password" />
                            <label asp-for="Input.Password">Password</label>
                            <span asp-validation-for="Input.Password" class="text-danger small"></span>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <div class="form-check">
                                <input class="form-check-input" asp-for="Input.RememberMe" />
                                <label class="form-check-label small text-muted" asp-for="Input.RememberMe">
                                    Remember me
                                </label>
                            </div>
                            <a id="forgot-password" asp-page="./ForgotPassword" class="small text-decoration-none fw-semibold">
                                Forgot password?
                            </a>
                        </div>

                        <button id="login-submit" type="submit" class="w-100 btn btn-primary btn-lg rounded-pill shadow-sm mb-3">
                            Sign In
                        </button>

                        <div class="text-center mt-3">
                            <p class="small text-muted mb-0">
                                Don't have an account? 
                                <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="fw-bold text-decoration-none">
                                    Create one now
                                </a>
                            </p>
                        </div>
                    </form>
                </div>
            </div>

            <div class="text-center mt-4">
                <a asp-area="" asp-page="/Index" class="auth-back-link small">
                    &larr; Back to Home
                </a>
            </div>
        </div>
    </div>
</div>
