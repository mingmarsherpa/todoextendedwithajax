@page
@model TodoView.Pages.Todos.DetailsModel

@{
    ViewData["Title"] = "Task Details";
}

<div class="page-shell">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-7">
            
            <section class="page-hero mb-4">
                <div class="d-flex justify-content-between align-items-end flex-wrap gap-3">
                    <div>
                        <span class="eyebrow">Task Overview</span>
                        <h1 class="display-6 mb-2">@Html.DisplayFor(model => model.Todo.Title)</h1>
                        <nav aria-label="breadcrumb">
                            <ol class="breadcrumb">
                                <li class="breadcrumb-item"><a asp-page="./Index">My Todos</a></li>
                                <li class="breadcrumb-item active">View</li>
                            </ol>
                        </nav>
                    </div>
                    <a asp-page="./Edit" asp-route-id="@Model.Todo.Id" class="btn btn-light">
                        <i class="bi bi-pencil me-1"></i> Edit Task
                    </a>
                </div>
            </section>

            <section class="panel-card">
                <div class="detail-grid">
                    <div class="detail-card">
                        <span class="label">Status</span>
                        <div>
                                @if (Model.Todo.IsDone)
                                {
                                    <span class="status-pill status-pill-done">
                                        <i class="bi bi-check2-circle me-1"></i> Completed
                                    </span>
                                }
                                else
                                {
                                    <span class="status-pill status-pill-progress">
                                        <i class="bi bi-hourglass-split me-1"></i> In Progress
                                    </span>
                                }
                        </div>
                    </div>

                    <div class="detail-card">
                        <span class="label">Description</span>
                        <p class="value fw-normal lh-base">
                                @if (string.IsNullOrWhiteSpace(Model.Todo.Description))
                                {
                                    <em class="text-muted">No description provided for this task.</em>
                                }
                                else
                                {
                                    @Html.DisplayFor(model => model.Todo.Description)
                                }
                        </p>
                    </div>

                    <div class="detail-card">
                        <span class="label">Task Id</span>
                        <p class="value"><code>#@Model.Todo.Id</code></p>
                    </div>
                </div>

                <div class="d-flex pt-4 mt-4 border-top justify-content-between align-items-center flex-wrap gap-2">
                    <a asp-page="./Index" class="auth-back-link">
                        <i class="bi bi-arrow-left me-1"></i> Return to List
                    </a>
                </div>
            </section>
        </div>
    </div>
</div>
