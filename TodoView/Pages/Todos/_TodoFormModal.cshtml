@model TodoView.Pages.Todos.IndexModel

<div class="modal-header border-0 pb-0">
    <div>
        <h5 class="modal-title">@Model.ModalTitle</h5>
        <p class="text-muted mb-0">@Model.ModalDescription</p>
    </div>
    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
</div>

<div class="modal-body pt-3">
    <form method="post"
          action="@Model.FormAction"
          class="js-ajax-form"
          novalidate
          data-refresh-target="#todo-list-container"
          data-success-action="@(Model.Todo.Id == 0 ? "create" : "edit")"
          data-success-title="@(Model.Todo.Id == 0 ? "Task created" : "Task updated")"
          data-success-tone="success">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="All" class="alert alert-danger p-2 small"></div>
        <input type="hidden" asp-for="Todo.Id" />
        <input type="hidden" asp-for="ViewMode" />
        <input type="hidden" asp-for="StatusFilter" />
        <input type="hidden" asp-for="SearchTerm" />

        <div class="mb-3">
            <label asp-for="Todo.Title" class="form-label fw-bold"></label>
            <input asp-for="Todo.Title" class="form-control" placeholder="What needs to be done?" />
            <span asp-validation-for="Todo.Title" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Todo.Description" class="form-label fw-bold"></label>
            <textarea asp-for="Todo.Description" class="form-control" rows="3" placeholder="Add some details..."></textarea>
            <span asp-validation-for="Todo.Description" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Todo.ReminderAt" class="form-label fw-bold"></label>
            <input asp-for="Todo.ReminderAt" type="datetime-local" class="form-control" />
            <span asp-validation-for="Todo.ReminderAt" class="text-danger small"></span>
            <div class="form-text">Leave this empty to skip reminders. The popup appears while this page is open.</div>
        </div>

        <div class="mb-0">
            <div class="form-check form-switch">
                <input class="form-check-input" type="checkbox" asp-for="Todo.IsDone" id="todo-status-switch">
                <label class="form-check-label fw-bold" for="todo-status-switch">
                    Mark as completed
                </label>
            </div>
        </div>

        <div class="d-flex justify-content-end gap-2 mt-4">
            <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
            <button type="submit" class="btn btn-primary">@Model.SubmitButtonText</button>
        </div>
    </form>
</div>
