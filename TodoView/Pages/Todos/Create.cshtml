@page
@model TodoView.Pages.Todos.CreateModel

@{
    ViewData["Title"] = "Create New Task";
}

<div class="page-shell">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="auth-card">
                <div class="auth-card-header">
                    <h4 class="mb-2"><i class="bi bi-plus-circle me-2"></i>Create New Todo</h4>
                    <p class="mb-0">Capture the task title, add supporting details, and decide whether it starts completed.</p>
                </div>
                <div class="auth-card-body">
                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger p-2 small"></div>

                        <div class="mb-3">
                            <label asp-for="Todo.Title" class="form-label fw-bold"></label>
                            <input asp-for="Todo.Title" class="form-control" placeholder="What needs to be done?" />
                            <span asp-validation-for="Todo.Title" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Todo.Description" class="form-label fw-bold"></label>
                            <textarea asp-for="Todo.Description" class="form-control" rows="3" placeholder="Add some details..."></textarea>
                            <span asp-validation-for="Todo.Description" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" asp-for="Todo.IsDone" id="isDoneSwitch">
                                <label class="form-check-label fw-bold" for="isDoneSwitch">
                                    Mark as completed immediately?
                                </label>
                            </div>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="bi bi-check-lg"></i> Create Task
                            </button>
                            <a asp-page="Index" class="btn btn-outline-secondary">Cancel and go back</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
