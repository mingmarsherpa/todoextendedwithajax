@model TodoView.Pages.Todos.IndexModel

<div class="modal-header border-0 pb-0">
    <div>
        <h5 class="modal-title">Delete "@Model.Todo.Title"?</h5>
        <p class="text-muted mb-0">This removes the task from your list immediately.</p>
    </div>
    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
</div>

<div class="modal-body pt-3">
    <div class="alert alert-danger d-flex align-items-center" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>
        <div>This action cannot be undone.</div>
    </div>

    <div class="detail-grid">
        <div class="detail-card">
            <span class="label">Description</span>
            <p class="value fw-normal">
                @(string.IsNullOrWhiteSpace(Model.Todo.Description) ? "No description provided." : Model.Todo.Description)
            </p>
        </div>

        <div class="detail-card">
            <span class="label">Status</span>
            <div>
                @if (Model.Todo.IsDone)
                {
                    <span class="status-pill status-pill-done"><i class="bi bi-check-circle me-1"></i> Completed</span>
                }
                else
                {
                    <span class="status-pill status-pill-progress"><i class="bi bi-clock me-1"></i> Pending</span>
                }
            </div>
        </div>
    </div>
</div>

<div class="modal-footer border-0 pt-0">
    <form method="post"
          action="@Url.Page("./Index", "Delete", new { id = Model.Todo.Id, view = Model.ViewMode, status = Model.StatusFilter, q = Model.SearchTerm })"
          class="js-ajax-form"
          data-refresh-target="#todo-list-container">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Todo.Id" />
        <input type="hidden" asp-for="ViewMode" />
        <input type="hidden" asp-for="StatusFilter" />
        <input type="hidden" asp-for="SearchTerm" />
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="btn btn-danger">Confirm Delete</button>
    </form>
</div>
