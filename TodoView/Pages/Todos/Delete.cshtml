@page
@model TodoView.Pages.Todos.DeleteModel

@{
    ViewData["Title"] = "Confirm Delete";
}

<div class="page-shell">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            
            <div class="alert alert-danger d-flex align-items-center mb-4" role="alert">
                <i class="bi bi-exclamation-triangle-fill me-2 fs-4"></i>
                <div>
                    <strong>Careful!</strong> This action cannot be undone.
                </div>
            </div>

            <div class="auth-card">
                <div class="auth-card-header">
                    <h5 class="card-title mb-2">
                        <i class="bi bi-trash3 me-2"></i>Delete This Task?
                    </h5>
                    <p class="mb-0">Review the details below before permanently removing this item from your list.</p>
                </div>
                
                <div class="auth-card-body">
                    <p class="text-muted mb-4">Are you sure you want to remove the following item?</p>
                    
                    <div class="detail-grid mb-4">
                        <div class="detail-card">
                            <span class="label">Title</span>
                            <p class="value fs-5">@Html.DisplayFor(model => model.Todo.Title)</p>
                        </div>
                        
                        <div class="detail-card">
                            <span class="label">Description</span>
                            <p class="value fw-normal">
                                @(string.IsNullOrEmpty(Model.Todo.Description) ? "No description provided." : Model.Todo.Description)
                            </p>
                        </div>

                        <div class="detail-card">
                            <span class="label">Status</span>
                            <div>
                                @if (Model.Todo.IsDone)
                                {
                                    <span class="status-pill status-pill-done"><i class="bi bi-check-circle me-1"></i> Completed</span>
                                }
                                else
                                {
                                    <span class="status-pill status-pill-progress"><i class="bi bi-clock me-1"></i> Pending</span>
                                }
                            </div>
                        </div>
                    </div>

                    <form method="post" class="d-flex justify-content-between align-items-center">
                        <input type="hidden" asp-for="Todo.Id" />
                        
                        <a asp-page="./Index" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left"></i> Keep Task
                        </a>
                        
                        <button type="submit" class="btn btn-danger px-4">
                            <i class="bi bi-trash3"></i> Confirm Delete
                        </button>
                    </form>
                </div>
            </div>

            <div class="text-center mt-3">
                <small class="text-muted">Managed by TodoView System</small>
            </div>
        </div>
    </div>
</div>
