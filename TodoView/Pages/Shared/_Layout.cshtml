@using TodoView.Authorization
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - TodoView</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
</head>
<body>
<div class="app-backdrop" aria-hidden="true"></div>

@* Only show header if "HideNavbar" is NOT set in the child page *@
@if (ViewData["HideNavbar"] == null)
{
    <header>
        <nav class="navbar navbar-expand-lg app-navbar mb-4">
            <div class="container app-container">
                <a class="navbar-brand fw-bold" asp-page="/Index">
                    <span class="brand-mark"><i class="bi bi-check2-square"></i></span>
                    <span>TodoView</span>
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse app-navbar-collapse" id="navbarContent">
                    <ul class="navbar-nav app-navbar-links">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-page="/Todos/Index">Todos</a>
                            </li>
                            @if (User.IsInRole(AppRoles.Admin))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-page="/Admin/Users/Index">Users</a>
                                </li>
                            }
                        }
                    </ul>

                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>
}

<div class="container app-container">
    <main role="main" class="pb-3">
        @RenderBody()
    </main>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
