@model TodoView.Pages.Admin.Users.DeleteModel

<div class="modal-header border-0 pb-0">
    <div>
        <h5 class="modal-title text-danger">Delete @Model.UserDetails.FullName?</h5>
        <p class="text-muted mb-0">This permanently removes the account and related records.</p>
    </div>
    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
</div>

<div class="modal-body pt-3">
    <div asp-validation-summary="ModelOnly" class="alert alert-danger p-2 small"></div>

    <div class="admin-kv mb-0">
        <div class="admin-kv-item">
            <span class="label">Name</span>
            <span class="value">@Model.UserDetails.FullName</span>
        </div>
        <div class="admin-kv-item">
            <span class="label">Email</span>
            <span class="value">@Model.UserDetails.Email</span>
        </div>
        <div class="admin-kv-item">
            <span class="label">User Id</span>
            <span class="value"><code>@Model.UserDetails.Id</code></span>
        </div>
    </div>
</div>

<div class="modal-footer border-0 pt-0">
    <form method="post"
          action="@Url.Page("./Delete", new { id = Model.UserDetails.Id })"
          class="js-ajax-form"
          data-refresh-target="#user-list-container"
          data-success-action="delete"
          data-success-title="User deleted"
          data-success-tone="success"
          data-success-user="@(string.IsNullOrWhiteSpace(Model.UserDetails.FullName) ? Model.UserDetails.Email : Model.UserDetails.FullName)">
        @Html.AntiForgeryToken()
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="btn btn-danger">Delete User</button>
    </form>
</div>
