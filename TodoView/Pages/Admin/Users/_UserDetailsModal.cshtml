@model TodoView.Pages.Admin.Users.DetailsModel
@{
    var initials = string.Concat(
        string.IsNullOrWhiteSpace(Model.UserDetails.FirstName) ? "" : Model.UserDetails.FirstName[0],
        string.IsNullOrWhiteSpace(Model.UserDetails.LastName) ? "" : Model.UserDetails.LastName[0]
    ).ToUpperInvariant();
}

<div class="modal-header border-0 pb-0">
    <div class="d-flex align-items-center gap-3">
        <span class="admin-avatar">@(string.IsNullOrWhiteSpace(initials) ? "U" : initials)</span>
        <div>
            <h5 class="modal-title mb-1">@Model.UserDetails.FirstName @Model.UserDetails.LastName</h5>
            <p class="text-muted mb-0">@Model.UserDetails.Email</p>
        </div>
    </div>
    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
</div>

<div class="modal-body pt-3">
    <div class="admin-kv">
        <div class="admin-kv-item">
            <span class="label">Full Name</span>
            <span class="value">@Model.UserDetails.FirstName @Model.UserDetails.LastName</span>
        </div>
        <div class="admin-kv-item">
            <span class="label">Address</span>
            <span class="value">@Model.UserDetails.Address</span>
        </div>
        <div class="admin-kv-item">
            <span class="label">Roles</span>
            <span class="value">
                @foreach (var role in Model.UserDetails.Roles)
                {
                    <span class="role-chip @(role == "Admin" ? "role-admin" : "role-user")">@role</span>
                }
            </span>
        </div>
        <div class="admin-kv-item">
            <span class="label">Created</span>
            <span class="value">@Model.UserDetails.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy HH:mm")</span>
        </div>
        <div class="admin-kv-item">
            <span class="label">User Id</span>
            <span class="value"><code>@Model.UserDetails.Id</code></span>
        </div>
    </div>
</div>

<div class="modal-footer border-0 pt-0">
    <button type="button"
            class="btn btn-outline-primary js-ajax-modal-trigger"
            data-url="@Url.Page("./Edit", new { id = Model.UserDetails.Id })">
        Edit
    </button>
    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
</div>
