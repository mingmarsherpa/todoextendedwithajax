@page "{id}"
@model TodoView.Pages.Admin.Users.DeleteModel
@{
    ViewData["Title"] = "Delete User";
}

<div class="admin-shell py-4">
    <section class="admin-panel admin-danger">
        <div class="admin-panel-header">
            <div>
                <span class="eyebrow text-danger">Danger Zone</span>
                <h1 class="h2 text-danger mb-2">Delete User</h1>
                <p class="text-muted mb-0">This permanently removes the account and any related records.</p>
            </div>
            <a asp-page="./Index" class="btn btn-outline-secondary">Back</a>
        </div>

        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

        <div class="admin-kv mb-4">
            <div class="admin-kv-item">
                <span class="label">Name</span>
                <span class="value">@Model.UserDetails.FullName</span>
            </div>
            <div class="admin-kv-item">
                <span class="label">Email</span>
                <span class="value">@Model.UserDetails.Email</span>
            </div>
            <div class="admin-kv-item">
                <span class="label">User Id</span>
                <span class="value"><code>@Model.UserDetails.Id</code></span>
            </div>
        </div>

        <form method="post" class="d-flex gap-2 flex-wrap">
            <button type="submit" class="btn btn-danger">Delete User</button>
            <a asp-page="./Index" class="btn btn-outline-secondary">Cancel</a>
        </form>
    </section>
</div>
